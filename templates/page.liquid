<style>
  .aw-page {
    padding: 80px 40px;
    background: #faf7f2;
    min-height: 60vh;
  }
  .aw-page__inner {
    max-width: 760px;
    margin: 0 auto;
  }
  .aw-page__title {
    font-family: var(--font-heading, 'Cormorant Garamond'), serif;
    font-size: clamp(2rem, 4vw, 3rem);
    color: #2c2420;
    line-height: 1.2;
    margin-bottom: 8px;
    font-weight: 400;
  }
  .aw-page__divider {
    width: 48px;
    height: 1px;
    background: #c17f59;
    margin: 24px 0 32px;
  }
  .aw-page__content {
    font-size: 1rem;
    color: #6b5e53;
    line-height: 1.9;
    font-weight: 300;
  }
  .aw-page__content p { margin: 0 0 16px; }
  .aw-page__content p:last-child { margin-bottom: 0; }
  .aw-page__content h2 {
    font-family: var(--font-heading, 'Cormorant Garamond'), serif;
    font-size: 1.6rem;
    color: #2c2420;
    margin: 32px 0 12px;
    font-weight: 400;
  }
  .aw-page__content h3 {
    font-size: 1.1rem;
    color: #2c2420;
    margin: 24px 0 8px;
    font-weight: 500;
  }
  .aw-page__content ul, .aw-page__content ol {
    padding-left: 20px;
    margin: 0 0 16px;
  }
  .aw-page__content li { margin-bottom: 6px; }
  @media (max-width: 768px) {
    .aw-page { padding: 48px 20px 60px; }
  }
</style>

<div class="aw-page">
  <div class="aw-page__inner">
    <h1 class="aw-page__title">{{ page.title }}</h1>
    <div class="aw-page__divider"></div>
    <div class="aw-page__content">{{ page.content }}</div>
  </div>
</div>
