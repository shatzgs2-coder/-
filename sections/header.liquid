<header class="header">
  <div class="container">
    <div class="header__inner">
      <a href="/" class="header__logo">
        {% if settings.logo %}
          <img src="{{ settings.logo | img_url: '200x' }}" alt="{{ shop.name }}" width="auto" height="40">
        {% else %}
          {{ shop.name }}
        {% endif %}
      </a>

      <nav>
        <ul class="header__nav">
          <li><a href="/" class="{% if template == 'index' %}active{% endif %}">{{ 'header.home' | t }}</a></li>
          <li><a href="/collections/all" class="{% if template contains 'collection' %}active{% endif %}">{{ 'header.shop' | t }}</a></li>
          <li><a href="/pages/about" class="{% if page.handle == 'about' %}active{% endif %}">{{ 'header.about' | t }}</a></li>
          <li><a href="/pages/faq" class="{% if page.handle == 'faq' %}active{% endif %}">{{ 'header.faq' | t }}</a></li>
          <li><a href="/pages/contact" class="{% if page.handle == 'contact' %}active{% endif %}">{{ 'header.contact' | t }}</a></li>
          <li><a href="/pages/shipping" class="{% if page.handle == 'shipping' %}active{% endif %}">{{ 'header.shipping' | t }}</a></li>
        </ul>
      </nav>

      <div class="header__icons">
        <a href="/search" class="header__icon" aria-label="{{ 'header.search' | t }}">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
            <circle cx="8.5" cy="8.5" r="6" stroke="currentColor" stroke-width="1.5"/>
            <path d="M13 13L18 18" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </a>
        <a href="/cart" class="header__icon" aria-label="{{ 'header.cart' | t }}">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
            <path d="M5 6L3 17h14L15 6H5z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
            <path d="M7 6a3 3 0 016 0" stroke="currentColor" stroke-width="1.5"/>
          </svg>
          <span class="header__cart-count" data-cart-count>{{ cart.item_count }}</span>
        </a>
        <button class="header__hamburger" aria-label="{{ 'header.menu' | t }}" aria-expanded="false">
          <span></span><span></span><span></span>
        </button>
      </div>
    </div>
  </div>
</header>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    }
  ]
}
{% endschema %}
