<div class="section">
  <div class="section__inner" style="max-width:900px;">
    <h1 class="section__heading">{{ 'cart.title' | t }}</h1>

    {% if cart.item_count > 0 %}
      <form action="/cart" method="post">
        {% for item in cart.items %}
          <div class="cart-item">
            <div class="cart-item__image">
              {% if item.image %}
                {{ item.image | image_url: width: 100 | image_tag: loading: 'lazy', alt: item.title | escape }}
              {% endif %}
            </div>
            <div>
              <div class="cart-item__title">{{ item.product.title }}</div>
              {% unless item.product.has_only_default_variant %}
                <div class="cart-item__variant">{{ item.variant.title }}</div>
              {% endunless %}
            </div>
            <div>
              <span style="font-size:0.92rem;color:#3A3A3A;">Qty: {{ item.quantity }}</span>
            </div>
            <div>
              <span style="font-size:0.95rem;color:#8B7355;font-weight:500;">{{ item.line_price | money }}</span>
            </div>
          </div>
        {% endfor %}
      </form>

      <div class="cart-footer">
        <span class="cart-footer__total">{{ 'cart.subtotal' | t }}: {{ cart.total_price | money }}</span>
        <button type="submit" form="cart-form" name="checkout" class="checkout-btn">{{ 'cart.checkout' | t }}</button>
      </div>
    {% else %}
      <p style="text-align:center;color:#6B5E53;padding:60px 0;font-size:1.1rem;">{{ 'cart.empty' | t }}</p>
      <p style="text-align:center;">
        <a href="/collections/all" style="color:#C17F59;text-decoration:underline;font-size:0.95rem;">Continue Shopping</a>
      </p>
    {% endif %}
  </div>
</div>
