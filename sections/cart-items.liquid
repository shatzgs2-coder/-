{% if cart.item_count > 0 %}
<div class="cart__items">
  {% for item in cart.items %}
  <div class="cart-item">
    <div class="cart-item__image">
      {% if item.image %}
        <img src="{{ item.image | img_url: '200x' }}" alt="{{ item.title | escape }}" width="100" height="100" loading="lazy">
      {% else %}
        {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
      {% endif %}
    </div>
    <div class="cart-item__details">
      <h3 class="cart-item__title">{{ item.product.title }}</h3>
      {% if item.variant.title != 'Default Title' %}
        <p class="cart-item__variant">{{ item.variant.title }}</p>
      {% endif %}
      <div class="cart-item__quantity">
        <button class="cart-item__quantity-btn minus" aria-label="Decrease quantity">-</button>
        <span class="cart-item__quantity-value">{{ item.quantity }}</span>
        <button class="cart-item__quantity-btn plus" aria-label="Increase quantity">+</button>
      </div>
      <a href="/cart/change?line={{ forloop.index }}&quantity=0" class="cart-item__remove">{{ 'cart.remove' | t }}</a>
    </div>
    <div class="cart-item__price">{{ item.line_price | money }}</div>
  </div>
  {% endfor %}
</div>
{% endif %}

{% schema %}
{
  "name": "Cart Items",
  "settings": []
}
{% endschema %}
