<section class="hero">
  <div class="hero__bg" style="background-image: url('{{ 'hero-bg.jpg' | asset_url }}');"></div>
  <div class="hero__overlay"></div>
  <div class="hero__content">
    <p class="hero__label">{{ section.settings.label | default: "Slow Living, Curated" }}</p>
    <h1 class="hero__title">{{ section.settings.heading | default: "The Beauty of Imperfection" }}</h1>
    <p class="hero__subtitle">{{ section.settings.subtitle | default: "Thoughtfully sourced pieces that celebrate natural textures, muted tones, and the quiet elegance of wabi-sabi. For a home that breathes." }}</p>
    {% if section.settings.cta_text != blank %}
      <a href="{{ section.settings.cta_link | default: '/collections/all' }}" class="hero__cta">{{ section.settings.cta_text }}</a>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Label",
      "default": "Slow Living, Curated"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The Beauty of Imperfection"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Thoughtfully sourced pieces that celebrate natural textures, muted tones, and the quiet elegance of wabi-sabi. For a home that breathes."
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA Text",
      "default": "Explore Collection"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA Link",
      "default": "/collections/all"
    }
  ],
  "presets": [
    {
      "name": "Hero",
      "category": "Image"
    }
  ]
}
{% endschema %}
