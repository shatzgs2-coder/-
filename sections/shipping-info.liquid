<section class="section">
  <div class="section__inner" style="max-width:900px;">
    <h1 class="section__heading">Shipping & Returns</h1>
    <p class="section__subtitle">Everything you need to know about delivery and returns.</p>

    <h3 style="font-family:var(--font-heading);font-size:1.4rem;color:#2C2420;margin-bottom:16px;">Shipping Rates</h3>
    <table class="shipping-table">
      <thead>
        <tr>
          <th>Region</th>
          <th>Price</th>
          <th>Delivery Time</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td>Germany</td>
          <td style="color:#8B7355;font-weight:500;">€4.90</td>
          <td>2 - 4 Business Days</td>
        </tr>
        <tr>
          <td>EU</td>
          <td style="color:#8B7355;font-weight:500;">€8.90</td>
          <td>4 - 7 Business Days</td>
        </tr>
        <tr>
          <td>Free Shipping</td>
          <td style="color:#8B7355;font-weight:500;">Free</td>
          <td>On orders over €79 within EU</td>
        </tr>
      </tbody>
    </table>

    <div style="margin-top:60px;">
      <h2 class="section__heading" style="text-align:left;font-size:1.4rem;">Returns</h2>
      <p class="section__subtitle" style="text-align:left;max-width:none;margin-bottom:36px;">Not satisfied? We accept returns within 30 days of delivery. Items must be unused and in original packaging.</p>

      <div class="returns-steps">
        <div class="returns-step">
          <div class="returns-step__number">1</div>
          <h4>Contact Us</h4>
          <p>Email hello@aeladaily.com with your order number and reason for return.</p>
        </div>
        <div class="returns-step">
          <div class="returns-step__number">2</div>
          <h4>Pack Item</h4>
          <p>Place unused items in original packaging. Include your order confirmation.</p>
        </div>
        <div class="returns-step">
          <div class="returns-step__number">3</div>
          <h4>Ship Back</h4>
          <p>We'll provide a return label. Drop off at your nearest DHL location.</p>
        </div>
        <div class="returns-step">
          <div class="returns-step__number">4</div>
          <h4>Get Refund</h4>
          <p>Refund processed within 5 business days after we receive and inspect the return.</p>
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Shipping Info",
  "settings": [],
  "presets": [
    {
      "name": "Shipping Info",
      "category": "Page"
    }
  ]
}
{% endschema %}
