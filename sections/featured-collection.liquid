<div class="section">
  <div class="section__inner">
    {% if section.settings.title != blank %}
      <p class="section__label">{{ section.settings.label | default: "Curated for You" }}</p>
      <h2 class="section__heading">{{ section.settings.title }}</h2>
      <p class="section__subtitle">{{ section.settings.subtitle }}</p>
    {% endif %}

    {% assign collection = collections[section.settings.collection] %}
    {% if collection and collection.products.size > 0 %}
      <div class="product-grid">
        {% for product in collection.products limit: section.settings.products_to_show %}
          {% render 'product-card', product: product %}
        {% endfor %}
      </div>
    {% else %}
      <div class="product-grid">
        {% for i in (1..4) %}
          <div class="product-card">
            <div class="product-card__image">
              <img src="https://images.unsplash.com/photo-1616486338812-3dadae4b4ace?w=400&h=400&fit=crop" alt="Demo product" loading="lazy">
            </div>
            <h3 class="product-card__title">Demo Product {{ i }}</h3>
            <p class="product-card__price">Add products in Shopify Admin</p>
          </div>
        {% endfor %}
      </div>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Featured Collection",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Label",
      "default": "Curated for You"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Our Collection"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Pieces we love, selected for their quiet beauty and lasting quality."
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Products to show",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 4
    }
  ],
  "presets": [
    {
      "name": "Featured Collection",
      "category": "Collection"
    }
  ]
}
{% endschema %}
