<section class="section-spacing featured-collection">
  <div class="container">
    <div class="section-heading">
      <h2 class="section-heading__title">{{ section.settings.title }}</h2>
      {% if section.settings.subtitle != blank %}
      <p class="section-heading__subtitle">{{ section.settings.subtitle }}</p>
      {% endif %}
    </div>

    <div class="product-grid">
      {% assign collection = collections[section.settings.collection] %}
      {% if collection and collection.products_count > 0 %}
        {% assign limit = section.settings.products_count | default: 4 %}
        {% for product in collection.products limit: limit %}
          {% render 'product-card', product: product %}
        {% endfor %}
      {% else %}
        {%- comment -%} Demo products with real images when no collection is set {%- endcomment -%}
        <a href="#" class="product-card">
          <div class="product-card__image" style="background-image:url('https://images.unsplash.com/photo-1600166898405-da9535204843?w=600&h=600&fit=crop')">
            <img src="https://images.unsplash.com/photo-1600166898405-da9535204843?w=600&h=600&fit=crop"
                 alt="Ceramic Vase" loading="lazy">
          </div>
          <div class="product-card__info">
            <h3 class="product-card__title">Ceramic Wabi-Sabi Vase</h3>
            <span class="product-card__price">€34.00</span>
          </div>
        </a>
        <a href="#" class="product-card">
          <div class="product-card__image" style="background-image:url('https://images.unsplash.com/photo-1586101904776-1a80b1c2a65f?w=600&h=600&fit=crop')">
            <img src="https://images.unsplash.com/photo-1586101904776-1a80b1c2a65f?w=600&h=600&fit=crop"
                 alt="Linen Throw Blanket" loading="lazy">
          </div>
          <div class="product-card__info">
            <h3 class="product-card__title">Linen Throw Blanket</h3>
            <span class="product-card__price">€58.00</span>
          </div>
        </a>
        <a href="#" class="product-card">
          <div class="product-card__image" style="background-image:url('https://images.unsplash.com/photo-1555041469-a586c61ea9bc?w=600&h=600&fit=crop')">
            <img src="https://images.unsplash.com/photo-1555041469-a586c61ea9bc?w=600&h=600&fit=crop"
                 alt="Wooden Tray Set" loading="lazy">
          </div>
          <div class="product-card__info">
            <h3 class="product-card__title">Handmade Wooden Tray</h3>
            <span class="product-card__price">€42.00</span>
          </div>
        </a>
        <a href="#" class="product-card">
          <div class="product-card__image" style="background-image:url('https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=600&h=600&fit=crop')">
            <img src="https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=600&h=600&fit=crop"
                 alt="Cotton Cushion Cover" loading="lazy">
          </div>
          <div class="product-card__info">
            <h3 class="product-card__title">Organic Cotton Cushion</h3>
            <span class="product-card__price">€28.00</span>
          </div>
        </a>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Featured Collection",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Featured Products"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Our best-selling wabi-sabi home essentials"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_count",
      "label": "Products to show",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 4
    }
  ],
  "presets": [
    {
      "name": "Featured Collection",
      "category": "Collection"
    }
  ]
}
{% endschema %}
