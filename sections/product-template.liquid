<section class="section-spacing product-template">
  <div class="container">
    <div class="product-main">
      <div class="product-main__media">
        {% if product.featured_media %}
          <img
            src="{{ product.featured_media | img_url: '1000x' }}"
            srcset="{{ product.featured_media | img_url: '600x' }} 600w, {{ product.featured_media | img_url: '1000x' }} 1000w"
            sizes="(max-width: 768px) 100vw, 600px"
            alt="{{ product.featured_media.alt | escape }}"
            width="600"
            height="600"
            loading="eager"
          >
        {% else %}
          {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
        {% endif %}
      </div>

      <div class="product-main__info">
        <h1 class="product-main__title">{{ product.title }}</h1>

        <div class="product-main__price" id="product-price">
          {% if product.compare_at_price > product.price %}
            <span class="product-card__compare-price">{{ product.compare_at_price | money }}</span>
          {% endif %}
          <span id="variant-price">{{ product.price | money }}</span>
        </div>

        {% if product.description != blank %}
          <div class="product-main__description">
            {{ product.description }}
          </div>
        {% endif %}

        {%- comment -%} Product Options / Variants {%- endcomment -%}
        {% form 'product', product, class: 'product-form', id: 'product-form' %}
          {%- assign has_variants = false -%}
          {%- for option in product.options_with_values -%}
            {%- assign has_variants = true -%}
            <div class="product-form__option">
              <label class="product-form__option-label">
                {{ option.name }}: <span class="product-form__selected-value" data-option-index="{{ forloop.index0 }}">{{ option.selected_value }}</span>
              </label>
              <div class="product-form__option-values">
                {%- for value in option.values -%}
                  {%- assign variant_for_value = nil -%}
                  {%- for variant in product.variants -%}
                    {%- if variant.options[forloop.parentloop.index0] == value -%}
                      {%- assign variant_for_value = variant -%}
                      {%- break -%}
                    {%- endif -%}
                  {%- endfor -%}
                  <button
                    type="button"
                    class="product-form__option-btn {% if option.selected_value == value %}is-active{% endif %}"
                    data-option-index="{{ option.position }}"
                    data-value="{{ value | escape }}"
                    {% unless variant_for_value.available %}disabled{% endunless %}
                  >
                    {{ value }}
                  </button>
                {%- endfor -%}
              </div>
            </div>
          {%- endfor -%}

          <input type="hidden" name="id" id="variant-id" value="{{ product.selected_or_first_available_variant.id }}">

          <div class="product-form__quantity">
            <label for="Quantity">{{ 'product.quantity' | t }}</label>
            <div class="qty-control">
              <button type="button" class="qty-control__btn qty-control__btn--minus" aria-label="Decrease">−</button>
              <input type="number" id="Quantity" name="quantity" value="1" min="1" class="qty-control__input">
              <button type="button" class="qty-control__btn qty-control__btn--plus" aria-label="Increase">+</button>
            </div>
          </div>

          <button
            type="submit"
            name="add"
            class="btn btn-primary product-form__add-to-cart"
            {% unless product.available %}disabled{% endunless %}
          >
            {% if product.available %}
              {{ 'product.add_to_cart' | t }}
            {% else %}
              {{ 'product.sold_out' | t }}
            {% endif %}
          </button>
        {% endform %}

        <div class="product-main__specs">
          <h3>{{ 'product.specifications' | t }}</h3>
          {%- comment -%} Show product options as specs (always show, not just metafields) {%- endcomment -%}
          {%- for option in product.options_with_values -%}
            <p><strong>{{ option.name }}:</strong> {{ option.selected_value }}</p>
          {%- endfor -%}
          {%- if product.type != blank -%}
            <p><strong>Category:</strong> {{ product.type }}</p>
          {%- endif -%}
          {%- if product.vendor != blank -%}
            <p><strong>Brand:</strong> {{ product.vendor }}</p>
          {%- endif -%}
        </div>
      </div>
    </div>
  </div>

  <script type="application/json" id="product-variants-data">
    {
      "variants": [
        {%- for variant in product.variants -%}
          {
            "id": {{ variant.id }},
            "title": {{ variant.title | json }},
            "price": {{ variant.price | json }},
            "compare_at_price": {{ variant.compare_at_price | json }},
            "available": {{ variant.available | json }},
            "options": {{ variant.options | json }}
          }{% unless forloop.last %},{% endunless %}
        {%- endfor -%}
      ],
      "options": [
        {%- for option in product.options_with_values -%}
          {
            "name": {{ option.name | json }},
            "position": {{ option.position }},
            "values": {{ option.values | json }}
          }{% unless forloop.last %},{% endunless %}
        {%- endfor -%}
      ]
    }
  </script>
</section>

{% schema %}
{
  "name": "Product Template",
  "settings": []
}
{% endschema %}
