<div class="container">
  <div class="collection-toolbar">
    <span>{{ collection.products_count }} products</span>
    <div class="collection-toolbar__sort">
      <select id="SortBy">
        <option value="manual">{{ 'collection.sort_by' | t }}: Featured</option>
        <option value="best-selling">Best Selling</option>
        <option value="title-ascending">Alphabetically, A-Z</option>
        <option value="title-descending">Alphabetically, Z-A</option>
        <option value="price-ascending">Price, low to high</option>
        <option value="price-descending">Price, high to low</option>
        <option value="created-descending">Date, new to old</option>
        <option value="created-ascending">Date, old to new</option>
      </select>
    </div>
  </div>

  <div class="product-grid">
    {% for product in collection.products %}
      {% render 'product-card', product: product %}
    {% else %}
      <div class="cart__empty" style="grid-column:1/-1">
        <p>{{ 'collection.no_products' | t }}</p>
      </div>
    {% endfor %}
  </div>
</div>

{% schema %}
{
  "name": "Product Grid",
  "settings": []
}
{% endschema %}
