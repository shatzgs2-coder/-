<div class="collection-banner">
  <h1 class="collection-banner__title">{{ collection.title }}</h1>
  {% if collection.products_count > 0 %}
    <p class="collection-banner__count">{{ collection.products_count }} {{ 'collection.products' | t }}</p>
  {% endif %}
  {% if collection.description != blank %}
    <p class="collection-banner__count" style="max-width:600px;margin:8px auto 0;">{{ collection.description }}</p>
  {% endif %}
</div>

{% schema %}
{
  "name": "Collection Banner",
  "settings": []
}
{% endschema %}
