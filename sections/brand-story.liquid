<section class="brand-story" id="story">
  <div class="brand-story__image" style="background-image: url('{{ 'brand-story-bg.jpg' | asset_url }}');"></div>
  <div class="brand-story__text">
    <p class="brand-story__label">{{ section.settings.label | default: "Our Story" }}</p>
    <h2 class="brand-story__title">{{ section.settings.title | default: "Where Japandi Meets Wabi-Sabi" }}</h2>
    <div class="brand-story__desc">
      {{ section.settings.story_text }}
    </div>
    {% if section.settings.button_text != blank %}
      <a href="{{ section.settings.button_link | default: '/pages/about' }}" class="brand-story__btn">{{ section.settings.button_text }}</a>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Brand Story",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Label",
      "default": "Our Story"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Where Japandi Meets Wabi-Sabi"
    },
    {
      "type": "richtext",
      "id": "story_text",
      "label": "Story Text",
      "default": "<p>Born from a love for quiet luxury and mindful living, Aela Daily curates pieces that bring harmony into everyday spaces. Each item in our collection is thoughtfully selected to honor the beauty of imperfection \u2014 the essence of <em>wabi-sabi</em>.</p><p>We work with artisans across Europe and Asia who craft with natural materials: linen, cotton rope, solid wood, and soy wax. No two pieces are exactly alike \u2014 and that's precisely the point.</p><p>We believe your home should tell a story: of natural textures, muted tones, and the gentle rhythm of Scandinavian simplicity meeting Japanese warmth.</p>"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Discover More"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link",
      "default": "/pages/about"
    }
  ],
  "presets": [
    {
      "name": "Brand Story",
      "category": "Text"
    }
  ]
}
{% endschema %}
