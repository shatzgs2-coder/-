{% if cart.item_count > 0 %}
<div class="cart-summary">
  <div class="cart-summary__row">
    <span>{{ 'cart.subtotal' | t }}</span>
    <span>{{ cart.total_price | money }}</span>
  </div>
  <div class="cart-summary__row">
    <span>{{ 'cart.shipping' | t }}</span>
    <span>{{ 'cart.shipping_calc' | t }}</span>
  </div>
  <div class="cart-summary__row cart-summary__row--total">
    <span>{{ 'cart.order_total' | t }}</span>
    <span>{{ cart.total_price | money }}</span>
  </div>
  <div class="cart-summary__checkout">
    <a href="/checkout" class="btn btn-primary btn-full">{{ 'cart.checkout' | t }}</a>
    <p style="text-align:center;font-size:12px;color:var(--color-body);margin-top:12px">
      {{ 'cart.secure' | t }}
    </p>
  </div>
</div>
{% endif %}

{% schema %}
{
  "name": "Cart Footer",
  "settings": []
}
{% endschema %}
